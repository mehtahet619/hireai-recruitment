# Copy to .env and fill in. If no API key is provided, the app runs in MOCK mode.

# B2B Auth
JWT_SECRET=change-me-in-production
# LLM selection: "gemini" or "mistral"
LLM_PROVIDER=

# Gemini settings (get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Mistral settings (get a key at https://console.mistral.ai/)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

LLM_TIMEOUT=60
USE_MOCK_LLM=
CORS_ORIGINS=http://localhost:5173

# Production persistence (optional locally; required on Render)
VALKEY_URL=
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_PUBLIC_BASE=
